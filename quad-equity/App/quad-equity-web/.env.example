# CMS API base URL including /api prefix (required for dynamic pages & navigation)
# Example: http://localhost:3000/api
VITE_API_BASE_URL=

# Slug of the published page served at "/" (default: home)
VITE_HOME_PAGE_SLUG=home

# Footer template page slug (templateKey footer-template in admin)
VITE_FOOTER_PAGE_SLUG=footer

# Locale key for multilingual CMS fields (default: en)
# VITE_CMS_LANG=en
