# MongoDB
DATABASE_URL=mongodb://localhost:27017/quadequity-cms

APP_NAME=Quad Equity CMS
APP_URL=http://localhost:3050
PORT=3050

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_ID=1d

# Must match quad-equity-admin VITE_CRYPTO_TOKEN for CryptoGuard
CRYPTO_TOKEN=

PAGE_LIMIT=10
WEB_URL=http://localhost:5174

# Optional — `npm run seed:admin` creates / updates super admin (role_id 1)
# SEED_ADMIN_EMAIL=admin@quad-equity.local
# SEED_ADMIN_PASSWORD=
# SEED_ADMIN_FIRST_NAME=Admin
# SEED_ADMIN_LAST_NAME=User
# SEED_ADMIN_MOBILE=0000000000
